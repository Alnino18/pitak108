rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    match /rooms/{roomId} {
      // Любой вошедший пользователь может читать комнату (нужен код, чтобы узнать id)
      // и создавать/обновлять её — авторитетность хода проверяется в engine.js на клиенте.
      // Для полностью "нечитерского" варианта эту логику стоит перенести в Cloud Functions.
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();

      match /messages/{messageId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      }

      match /reactions/{reactionId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      }

      // Карты на руке у каждого игрока — теперь отдельно от документа комнаты
      // (это уменьшает объём данных, которые скачивает каждый клиент).
      // Читать и писать может любой участник — так же, как и с самим документом
      // комнаты: авторитетность хода проверяется в engine.js на клиенте, а не тут.
      // Это нужно, потому что при подсчёте очков в конце раунда движок должен
      // прочитать карты ВСЕХ игроков, а не только свои.
      // Для настоящей приватности карт (чтобы даже через код нельзя было подсмотреть
      // чужие карты) нужно перенести подсчёт очков в Cloud Functions.
      match /hands/{handId} {
        allow read, write: if signedIn();
      }

      match /voicePeers/{peerId} {
        allow read: if signedIn();
        allow write: if signedIn() && request.auth.uid == peerId;
      }

      match /voiceSignals/{signalId} {
        allow read, write: if signedIn();

        match /candidates/{candidateId} {
          allow read: if signedIn();
          allow create: if signedIn() && request.resource.data.from == request.auth.uid;
        }
      }
    }
  }
}
